<!DOCTYPE html>
<html>

<head>

    <title>Hotel Room List</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background: #f8f9fb;
        }

        .table thead th {
            background: #212529;
            color: #fff;
            border-color: #2c3136;
            vertical-align: middle;
        }

        .table td {
            vertical-align: middle;
        }

        .table tbody tr:nth-child(even) {
            background: #f2f2f2;
        }

        .room-photo {
            width: 72px;
            height: 54px;
            object-fit: cover;
            border-radius: 4px;
            border: 1px solid #d9dee3;
        }
    </style>

</head>

<body class="container py-4">

    <% const formatter = new Intl.NumberFormat("id-ID"); %>

    <div class="d-flex flex-wrap align-items-center gap-2 mb-3">

        <form class="d-flex flex-grow-1 gap-2" method="GET" action="/">

            <input type="text" name="search" value="<%= search %>" class="form-control"
                placeholder="Search room...">

            <button class="btn btn-success">Search</button>

        </form>

        <a href="/add" class="btn btn-primary">Add New Room</a>

    </div>

    <table class="table table-bordered table-hover">

        <thead>

            <tr>
                <th>Photo</th>
                <th>Code</th>
                <th>Name</th>
                <th>Description</th>
                <th>Size</th>
                <th>Facilities</th>
                <th>Price</th>
                <th>Guests</th>
                <th>Available</th>
                <th>Action</th>
            </tr>

        </thead>

        <tbody>

            <% rooms.forEach(room=> { %>

                <tr>

                    <td>
                        <img src="/uploads/<%= room.photo %>" class="room-photo" alt="room photo">
                    </td>

                    <td>
                        <%= room.code_room %>
                    </td>
                    <td>
                        <%= room.name %>
                    </td>
                    <td>
                        <%= room.description %>
                    </td>
                    <td>
                        <%= room.room_size %>
                    </td>
                    <td>
                        <%= room.facilities %>
                    </td>
                    <td>
                        <%= room.price !== null && room.price !== undefined ? "Rp " + formatter.format(room.price) : "-" %>
                    </td>
                    <td>
                        <%= room.guests %>
                    </td>
                    <td>
                        <% const isAvailable = ["1","true","on","yes"].includes(String(room.available || "").toLowerCase()); %>
                        <span class="badge <%= isAvailable ? "bg-success" : "bg-secondary" %>">
                            <%= isAvailable ? "Yes" : "No" %>
                        </span>
                    </td>

                    <td>

                        <a href="/edit/<%= room.id %>" class="btn btn-warning btn-sm">Edit</a>

                        <form action="/delete/<%= room.id %>" method="POST" class="d-inline"
                            onsubmit="return confirm('Delete room?')">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>

                    </td>

                </tr>

                <% }) %>

        </tbody>

    </table>

    <% if (totalPages > 1) { %>
        <nav class="d-flex justify-content-center">
            <ul class="pagination">
                <% for (let p = 1; p <= totalPages; p++) { %>
                    <li class="page-item <%= p === page ? "active" : "" %>">
                        <a class="page-link" href="/?search=<%= encodeURIComponent(search) %>&page=<%= p %>">
                            <%= p %>
                        </a>
                    </li>
                <% } %>
            </ul>
        </nav>
    <% } %>

</body>

</html>
