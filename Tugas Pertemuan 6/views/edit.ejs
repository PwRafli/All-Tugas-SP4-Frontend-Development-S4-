<!DOCTYPE html>
<html>

<head>

    <title>Edit Homestay</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background: #f8f9fb;
        }

        .form-card {
            max-width: 820px;
            margin: 0 auto;
            border: 1px solid #e2e6ea;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
        }
    </style>

</head>

<body class="container py-4">

    <% const availableChecked = ["1","true","on","yes"].includes(String(room.available || "").toLowerCase()); %>

    <div class="card form-card">
        <div class="card-body p-4">
            <h4 class="text-center mb-4">Edit Homestay</h4>

            <form action="/edit/<%= room.id %>" method="POST" enctype="multipart/form-data">

                <div class="mb-3">
                    <label class="form-label d-block">Foto Saat Ini</label>
                    <img src="/uploads/<%= room.photo %>" width="120" class="rounded border">
                </div>

                <input type="hidden" name="oldphoto" value="<%= room.photo %>">

                <div class="mb-3">
                    <label class="form-label">Ganti Foto</label>
                    <input type="file" name="photo" class="form-control" accept="image/*">
                </div>

                <div class="mb-3">
                    <label class="form-label">Nama Homestay</label>
                    <input name="name" value="<%= room.name %>" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Kode Kamar</label>
                    <input name="code_room" value="<%= room.code_room %>" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Ukuran Kamar</label>
                    <input name="room_size" value="<%= room.room_size %>" class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label">Harga / Malam</label>
                    <input name="price" type="number" step="0.01" value="<%= room.price %>" class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label">Jumlah Tamu</label>
                    <input name="guests" type="number" value="<%= room.guests %>" class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label">Fasilitas</label>
                    <textarea name="facilities" class="form-control" rows="2"><%= room.facilities %></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Deskripsi</label>
                    <textarea name="description" class="form-control" rows="3"><%= room.description %></textarea>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="available" name="available" value="1"
                        <%= availableChecked ? "checked" : "" %>>
                    <label class="form-check-label" for="available">Tersedia</label>
                </div>

                <div class="d-grid gap-2">
                    <button class="btn btn-primary">Update</button>
                    <a href="/" class="btn btn-secondary">Batal</a>
                </div>

            </form>
        </div>
    </div>

</body>

</html>
